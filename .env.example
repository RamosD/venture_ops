# Variáveis do ambiente local integrado (Docker Compose) — VentureOps AI.
# Copie para `.env` (ignorado pelo git) e ajuste. NÃO commitar segredos reais.

# --- Backend ---
DJANGO_SECRET_KEY=dev-key-nao-usar-em-producao
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend

# --- PostgreSQL ---
POSTGRES_DB=ventureops
POSTGRES_USER=ventureops
POSTGRES_PASSWORD=ventureops_dev

# --- Portas publicadas no host (ajuste se estiverem ocupadas) ---
BACKEND_PORT=8000
FRONTEND_PORT=5173
DB_PORT=5433
