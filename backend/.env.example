# Configuração de ambiente do backend — VentureOps AI (F1-P02-PR01)
# Copie os valores para o ambiente (ou para um ficheiro .env carregado pelo seu
# shell/compose). NÃO versionar segredos reais. Um carregador automático de .env
# NÃO faz parte desta etapa; exporte as variáveis no ambiente antes de arrancar.

# --- Obrigatória ---
# Chave secreta da aplicação Django. Em falta, o arranque falha com mensagem clara.
DJANGO_SECRET_KEY=

# --- Opcionais nesta etapa (valores por defeito seguros para desenvolvimento) ---
# Modo debug (true|false). Por defeito: false.
DJANGO_DEBUG=false
# Hosts permitidos, separados por vírgula. Por defeito: localhost,127.0.0.1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
# Origens CORS permitidas, separadas por vírgula. Vazio = nenhuma (restritivo).
DJANGO_CORS_ALLOWED_ORIGINS=

# Cookies Secure (sessão/CSRF). false em desenvolvimento; true com TLS.
DJANGO_SECURE_COOKIES=false
# Origens de confiança para CSRF (separadas por vírgula), se cross-origin.
DJANGO_CSRF_TRUSTED_ORIGINS=

# --- Email (consola em dev; SMTP no piloto) ---
DJANGO_EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# Para SMTP real: django.core.mail.backends.smtp.EmailBackend + host/porta/credenciais
DJANGO_EMAIL_HOST=
DJANGO_EMAIL_PORT=25
DJANGO_EMAIL_HOST_USER=
DJANGO_EMAIL_HOST_PASSWORD=
DJANGO_EMAIL_USE_TLS=false
DJANGO_DEFAULT_FROM_EMAIL=no-reply@ventureops.local

# --- Recuperação e rate limiting (persistente em PostgreSQL) ---
PASSWORD_RESET_TTL_SECONDS=1800
RATE_LIMIT_LOGIN_MAX=5
RATE_LIMIT_LOGIN_WINDOW=300
RATE_LIMIT_RECOVERY_MAX=5
RATE_LIMIT_RECOVERY_WINDOW=900

# --- PostgreSQL (obrigatório; sem SQLite como persistência) ---
# NAME/USER/PASSWORD são obrigatórios; em falta, o arranque falha com mensagem clara.
POSTGRES_DB=ventureops
POSTGRES_USER=ventureops
POSTGRES_PASSWORD=
# HOST/PORT têm defaults (127.0.0.1:5432). O ambiente de desenvolvimento
# disponibilizado nesta etapa usa um PostgreSQL em contentor na porta 5433.
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_CONN_MAX_AGE=0
